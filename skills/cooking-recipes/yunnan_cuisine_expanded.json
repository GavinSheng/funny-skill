{
  "metadata": {
    "cuisine": "云南菜",
    "total_dishes": 25,
    "description": "云南菜以野生菌类、民族特色和独特香料为特色，融合了汉、彝、白、傣等多个民族的烹饪技法",
    "created_date": "2026-03-19"
  },
  "dishes": [
    {
      "name": "过桥米线",
      "difficulty": "中级",
      "prep_time": 30,
      "cook_time": 20,
      "servings": 2,
      "ingredients": [
        "米线300g",
        "鸡胸肉100g",
        "猪里脊100g",
        "鹌鹑蛋4个",
        "豆芽100g",
        "韭菜50g",
        "香菜适量",
        "鸡汤800ml",
        "鸡油2汤匙",
        "盐适量",
        "白胡椒粉适量"
      ],
      "steps": [
        "准备高汤：用老母鸡熬制浓鸡汤，保持高温",
        "肉类处理：鸡胸肉、猪里脊切薄片，越薄越好",
        "配菜准备：豆芽焯水，韭菜切段，香菜切碎",
        "鹌鹑蛋煮熟去壳",
        "米线用开水泡软",
        "上桌时先将滚烫的鸡汤倒入大碗中",
        "依次放入肉片、鹌鹑蛋、豆芽、韭菜",
        "最后加入米线，撒上香菜即可"
      ],
      "tips": "关键是要用滚烫的鸡汤，肉片要切得极薄，利用汤的温度烫熟",
      "regional_note": "云南蒙自传统名吃"
    },
    {
      "name": "汽锅鸡",
      "difficulty": "中级",
      "prep_time": 20,
      "cook_time": 180,
      "servings": 4,
      "ingredients": [
        "土鸡1只(约1.5kg)",
        "宣威火腿100g",
        "姜片5片",
        "枸杞20粒",
        "红枣6颗",
        "盐适量",
        "料酒2汤匙"
      ],
      "steps": [
        "土鸡斩块，用开水焯去血沫",
        "宣威火腿切片",
        "将鸡块、火腿片、姜片放入汽锅中",
        "加入枸杞、红枣",
        "汽锅放在装有水的锅上，密封好",
        "大火烧开后转小火蒸3小时",
        "出锅前加盐调味即可"
      ],
      "tips": "必须使用专用的汽锅，利用蒸汽循环原理，保持原汁原味",
      "regional_note": "云南建水特产，国家级非物质文化遗产"
    },
    {
      "name": "野生菌火锅",
      "difficulty": "高级",
      "prep_time": 30,
      "cook_time": 40,
      "servings": 4,
      "ingredients": [
        "牛肝菌200g",
        "鸡枞菌150g",
        "松茸100g",
        "青头菌100g",
        "鸡油菌100g",
        "土鸡半只",
        "宣威火腿50g",
        "姜片5片",
        "蒜瓣5瓣",
        "干辣椒5个",
        "花椒1茶匙",
        "盐适量"
      ],
      "steps": [
        "各种野生菌分别清洗干净",
        "土鸡斩块焯水",
        "锅中放鸡油，爆香姜蒜、干辣椒、花椒",
        "加入鸡块翻炒",
        "加入足量清水，大火烧开",
        "放入宣威火腿和各种野生菌",
        "小火炖煮30分钟",
        "加盐调味即可"
      ],
      "tips": "野生菌一定要确保新鲜，不认识的菌子不要采食，安全第一",
      "regional_note": "云南夏季特色，雨季野生菌最丰富"
    },
    {
      "name": "傣味柠檬鸡",
      "difficulty": "中级",
      "prep_time": 20,
      "cook_time": 15,
      "servings": 2,
      "ingredients": [
        "鸡腿肉300g",
        "青柠檬2个",
        "小米辣5个",
        "香茅1根",
        "香菜50g",
        "洋葱半个",
        "鱼露2汤匙",
        "糖1汤匙",
        "盐适量"
      ],
      "steps": [
        "鸡腿肉煮熟撕成丝",
        "青柠檬榨汁",
        "小米辣切碎，香茅拍扁切段",
        "洋葱切丝，香菜切段",
        "将所有调料混合：柠檬汁、鱼露、糖、盐",
        "加入鸡肉丝、小米辣、香茅、洋葱拌匀",
        "最后撒上香菜即可"
      ],
      "tips": "柠檬要用青柠檬，酸味更清新，小米辣根据口味调整用量",
      "regional_note": "西双版纳傣族特色菜"
    },
    {
      "name": "大理乳扇",
      "difficulty": "初级",
      "prep_time": 10,
      "cook_time": 5,
      "servings": 2,
      "ingredients": [
        "乳扇200g",
        "玫瑰酱50g",
        "白糖适量",
        "食用油适量"
      ],
      "steps": [
        "乳扇切成小块",
        "平底锅加热，放入少量油",
        "放入乳扇煎至两面金黄",
        "撒上白糖或蘸玫瑰酱食用"
      ],
      "tips": "乳扇是云南特有的奶制品，煎的时候火不要太大",
      "regional_note": "大理白族传统小吃"
    },
    {
      "name": "宣威火腿炒青椒",
      "difficulty": "初级",
      "prep_time": 10,
      "cook_time": 10,
      "servings": 2,
      "ingredients": [
        "宣威火腿150g",
        "青椒200g",
        "蒜瓣3瓣",
        "食用油适量"
      ],
      "steps": [
        "宣威火腿切片，青椒切丝",
        "蒜瓣切片",
        "热锅不放油，先煸炒火腿出油",
        "加入蒜片爆香",
        "放入青椒翻炒至断生即可"
      ],
      "tips": "宣威火腿本身很咸，不需要额外加盐",
      "regional_note": "云南宣威特产火腿"
    },
    {
      "name": "饵块炒腊肉",
      "difficulty": "中级",
      "prep_time": 15,
      "cook_time": 15,
      "servings": 2,
      "ingredients": [
        "饵块300g",
        "云南腊肉150g",
        "青蒜苗100g",
        "青椒100g",
        "酱油1汤匙",
        "盐适量",
        "食用油适量"
      ],
      "steps": [
        "饵块切片，腊肉切片",
        "青蒜苗切段，青椒切丝",
        "热锅放油，先炒腊肉出油",
        "加入饵块翻炒",
        "放入青椒、青蒜苗翻炒",
        "加酱油调味，炒匀即可"
      ],
      "tips": "饵块要选择新鲜的，腊肉要提前泡水去咸",
      "regional_note": "昆明传统家常菜"
    },
    {
      "name": "凉拌树花",
      "difficulty": "初级",
      "prep_time": 15,
      "cook_time": 5,
      "servings": 2,
      "ingredients": [
        "树花(地衣)100g",
        "小米辣3个",
        "香菜30g",
        "蒜末2瓣",
        "酱油2汤匙",
        "醋1汤匙",
        "糖1茶匙",
        "盐适量",
        "香油适量"
      ],
      "steps": [
        "树花用清水反复清洗干净",
        "用开水焯烫2分钟",
        "捞出沥干水分",
        "小米辣切碎，香菜切段",
        "将所有调料混合成调味汁",
        "加入树花、小米辣、香菜拌匀即可"
      ],
      "tips": "树花要彻底清洗干净，去除杂质",
      "regional_note": "滇西北山区特色野菜"
    },
    {
      "name": "破酥包",
      "difficulty": "高级",
      "prep_time": 120,
      "cook_time": 20,
      "servings": 8,
      "ingredients": [
        "面粉500g",
        "酵母5g",
        "猪油100g",
        "白糖200g",
        "玫瑰酱100g",
        "温水250ml"
      ],
      "steps": [
        "面粉分成两份，一份用酵母和温水和面",
        "另一份用猪油和面粉揉成油酥面",
        "发酵好的面团擀开，包入油酥面",
        "反复折叠擀开，形成层次",
        "玫瑰酱加糖调成馅料",
        "面团分成小剂子，包入馅料",
        "二次发酵30分钟",
        "蒸锅上汽后蒸15分钟即可"
      ],
      "tips": "关键是油酥面的比例和折叠次数，层次越多越好吃",
      "regional_note": "昆明传统名点"
    },
    {
      "name": "酸笋煮鱼",
      "difficulty": "中级",
      "prep_time": 20,
      "cook_time": 25,
      "servings": 3,
      "ingredients": [
        "草鱼1条(约600g)",
        "酸笋200g",
        "番茄2个",
        "小米辣5个",
        "姜片5片",
        "蒜瓣5瓣",
        "香茅1根",
        "香菜适量",
        "鱼露2汤匙",
        "盐适量"
      ],
      "steps": [
        "草鱼处理干净切块",
        "酸笋切片，番茄切块",
        "小米辣切段，香茅拍扁",
        "热锅放油，爆香姜蒜、小米辣、香茅",
        "加入番茄炒出红油",
        "加入酸笋翻炒",
        "加入足量清水烧开",
        "放入鱼块煮15分钟",
        "加鱼露、盐调味，撒香菜即可"
      ],
      "tips": "酸笋要选择发酵适中的，太酸会影响口感",
      "regional_note": "德宏傣族特色菜"
    }
  ]
}