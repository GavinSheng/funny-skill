    {
      "name": "挂炉烤鸭",
      "category": "满席",
      "difficulty": "高级",
      "prep_time": 120,
      "cook_time": 90,
      "servings": 4,
      "ingredients": [
        "北京填鸭1只(约2.5kg)",
        "麦芽糖50g",
        "清水200ml",
        "葱白100g",
        "黄瓜条100g",
        "甜面酱100g",
        "荷叶饼20张",
        "白糖20g"
      ],
      "steps": [
        "选鸭：选用北京填鸭，宰杀后去毛、去内脏，清洗干净",
        "充气：从鸭颈部切口处向皮下充气，使皮肉分离",
        "烫皮：用沸水浇淋鸭身，使鸭皮收缩紧绷",
        "上色：麦芽糖加水熬制成糖水，均匀涂抹在鸭身上",
        "晾干：挂在通风处晾干12小时以上",
        "烤制：挂炉明火烤制，先烤鸭背，再烤鸭胸，约90分钟",
        "片鸭：趁热片成108片，皮肉分离",
        "装盘：配葱丝、黄瓜条、甜面酱、荷叶饼上桌"
      ],
      "tips": "关键在于充气要均匀，上色要薄而均匀，烤制火候要掌握好",
      "historical_note": "清代宫廷御膳，乾隆皇帝最爱的菜品之一"
    },
