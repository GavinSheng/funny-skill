  "dishes": [
    {
      "name": "东坡肉",
      "difficulty": "中级",
      "prep_time": 30,
      "cook_time": 120,
      "servings": 4,
      "ingredients": [
        "五花肉500g",
        "黄酒300ml",
        "酱油100ml",
        "冰糖100g",
        "姜片5片",
        "葱段3根"
      ],
      "steps": [
        "五花肉切大块焯水",
        "炒糖色",
        "加入黄酒、酱油、冰糖",
        "小火慢炖2小时",
        "收汁装盘"
      ],
      "tips": "要用黄酒而不是料酒，炖煮时间要足够"
    },
    {
      "name": "西湖醋鱼",
      "difficulty": "中级",
      "prep_time": 20,
      "cook_time": 15,
      "servings": 2,
      "ingredients": [
        "草鱼1条(约600g)",
        "姜末20g",
        "醋50ml",
        "糖30g",
        "酱油20ml",
        "高汤200ml"
      ],
      "steps": [
        "草鱼处理干净",
        "鱼身划刀",
        "煮至断生",
        "调制酸甜汁",
        "淋在鱼上"
      ],
      "tips": "鱼要选择活的草鱼，煮的时间要掌握好"
    },
    {
      "name": "龙井虾仁",
