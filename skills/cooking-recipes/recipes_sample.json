{
  "recipes": [
    {
      "name": "宫保鸡丁",
      "cuisine": "川菜",
      "difficulty": "中级",
      "prep_time": 15,
      "cook_time": 10,
      "servings": 2,
      "ingredients": [
        "鸡胸肉 300克",
        "花生米 50克", 
        "干辣椒 10个",
        "花椒 1茶匙",
        "葱 2根",
        "姜 1小块",
        "蒜 3瓣",
        "酱油 2汤匙",
        "醋 1汤匙",
        "糖 1汤匙",
        "料酒 1汤匙",
        "淀粉 1汤匙",
        "盐 适量",
        "食用油 适量"
      ],
      "steps": [
        "鸡胸肉切丁，用料酒、盐、淀粉腌制10分钟",
        "干辣椒剪段，葱切段，姜蒜切片",
        "调制宫保汁：酱油、醋、糖、淀粉、水混合",
        "热锅凉油，放入花生米炒香，捞出备用",
        "锅中留底油，放入花椒和干辣椒炒香",
        "加入姜蒜爆香，放入鸡丁翻炒至变色",
        "倒入宫保汁，快速翻炒均匀",
        "最后加入炒好的花生米和葱段，翻炒均匀即可"
      ],
      "tips": "鸡肉要提前腌制，这样更嫩滑。花生米要最后放，保持酥脆。"
    },
    {
      "name": "泰式冬阴功汤",
      "cuisine": "泰国菜",
      "difficulty": "中级",
      "prep_time": 20,
      "cook_time": 25,
      "servings": 4,
      "ingredients": [
        "虾 300克",
        "香茅 2根",
        "柠檬叶 6片",
        "南姜 1小块",
        "小米辣 4个",
        "鱼露 2汤匙",
        "椰浆 200ml",
        "冬阴功酱 2汤匙",
        "蘑菇 150克",
        "番茄 1个",
        "青柠 2个",
        "香菜 适量",
        "盐 适量"
      ],
      "steps": [
        "虾去壳去线，香茅拍扁切段，南姜切片，小米辣切碎",
        "锅中加水，放入香茅、柠檬叶、南姜煮10分钟出香味",
        "加入冬阴功酱和小米辣，继续煮5分钟",
        "放入蘑菇和番茄煮3分钟",
        "加入虾仁煮至变色",
        "倒入椰浆，加入鱼露调味",
        "挤入青柠汁，撒上香菜即可"
      ],
      "tips": "冬阴功的关键是香茅、柠檬叶和南姜的搭配，这三样缺一不可。"
    },
    {
      "name": "法式洋葱汤",
      "cuisine": "法国菜",
      "difficulty": "初级",
      "prep_time": 15,
      "cook_time": 45,
      "servings": 4,
      "ingredients": [
        "黄洋葱 4个",
        "黄油 50克",
        "面粉 2汤匙",
        "白葡萄酒 100ml",
        "牛肉高汤 1升",
        "法棍面包 4片",
        "格鲁耶尔奶酪 100克",
        "百里香 1茶匙",
        "月桂叶 1片",
        "盐 适量",
        "黑胡椒 适量"
      ],
      "steps": [
        "洋葱切成细丝，用黄油小火慢炒30分钟至焦糖色",
        "撒入面粉，翻炒2分钟",
        "倒入白葡萄酒，煮至酒精挥发",
        "加入牛肉高汤、百里香、月桂叶，小火煮15分钟",
        "用盐和黑胡椒调味",
        "将汤倒入耐热碗中，放上烤过的法棍片",
        "撒上格鲁耶尔奶酪，放入烤箱200度烤至奶酪融化金黄"
      ],
      "tips": "洋葱一定要小火慢炒，这样才能充分焦糖化，汤的味道才会甜美。"
    }
  ]
}